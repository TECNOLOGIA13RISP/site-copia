<html>
<head>
  <meta charset="utf-8">
  <meta http-equiv="x-ua-compatible" content="ie=edge">
  <title>Formulário de Contato</title>
    <style>
      body {
        font-family: sans-serif;
        -webkit-font-smoothing: antialiased;
        font-size: 14px;
        line-height: 22px;
        margin: 0;
        padding: 0;
        -ms-text-size-adjust: 100%;
        font-weight: 300;
        -webkit-text-size-adjust: 100%;
      }
      h2 {
        color: #6B89BB;
        font-size: 20px;
        font-weight: bolder;
      }
      p {
        font-size: 16px;
        line-height: 22px;
        color: #212529;
      }
  </style>
</head>
<body>
  <h2>Formulário de Contato</h2>
  <hr>
  <p>Nome: {{nome}}</p>
  <p>E-mail: {{email}}</p>
  <p>Nome: {{telefone}}</p>
  <p><strong>Mensagem:</strong></p>
  <p>{{mensagem}}</p>
</body>
</html>
