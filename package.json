{
  "name": "react-avancado-boilerplate",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && cp ./public/sitemap.xml .next/static/sitemap.xml",
    "start": "next start",
    "lint": "eslint src --max-warnings=0",
    "test": "jest --maxWorkers=50%",
    "test:watch": "jest --watch --maxWorkers=25%",
    "test:ci": "jest --runInBand",
    "generate": "yarn plop --plopfile generators/plopfile.js",
    "storybook": "start-storybook -s ./public -p 6006",
    "build-storybook": "build-storybook -s ./public",
    "postinstall": "husky install",
    "postbuild": "next-sitemap"
  },
  "lint-staged": {
    "src/**/*": [
      "yarn lint --fix",
      "yarn test --findRelatedTests --bail"
    ]
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@sendgrid/mail": "^7.4.5",
    "@sentry/nextjs": "^6.13.2",
    "@storybook/addon-postcss": "^2.0.0",
    "@types/react-select": "^4.0.16",
    "@types/yup": "^0.29.13",
    "@unform/core": "^2.1.6",
    "@unform/web": "^2.1.6",
    "axios": "^1.5.0",
    "bootstrap": "4.6.0",
    "csstype": "^3.1.2",
    "date-fns": "^2.23.0",
    "fs": "^0.0.1-security",
    "js-cookie": "^3.0.0",
    "jsonwebtoken": "^8.5.1",
    "mssql": "^7.2.0",
    "next": "12.2.5",
    "next-pwa": "^5.2.24",
    "next-sitemap": "^1.6.164",
    "node-cpf": "^1.1.1",
    "nodemailer": "^6.7.0",
    "nodemailer-express-handlebars": "^4.0.0",
    "nookies": "^2.5.2",
    "numero-por-extenso": "^1.0.8",
    "react": "18.2.0",
    "react-bootstrap": "^1.6.1",
    "react-cookie-consent": "^6.2.4",
    "react-data-table-component": "^6.11.7",
    "react-dom": "18.2.0",
    "react-maskinput": "^3.2.0",
    "react-select": "^4.3.1",
    "react-switch": "^6.0.0",
    "react-tag-input": "^6.7.3",
    "react-to-pdf": "^0.0.14",
    "styled-components": "^5.3.10",
    "yup": "^0.32.9"
  },
  "devDependencies": {
    "@babel/core": "^7.14.6",
    "@babel/preset-typescript": "^7.14.5",
    "@fortawesome/fontawesome-svg-core": "^1.2.35",
    "@fortawesome/free-brands-svg-icons": "^5.15.3",
    "@fortawesome/free-solid-svg-icons": "^5.15.3",
    "@fortawesome/react-fontawesome": "^0.1.14",
    "@storybook/addon-essentials": "6.2.9",
    "@storybook/preset-scss": "^1.0.3",
    "@storybook/react": "6.2.9",
    "@testing-library/jest-dom": "^5.14.1",
    "@testing-library/react": "^11.2.7",
    "@types/axios": "^0.14.0",
    "@types/cookies": "^0.7.7",
    "@types/date-fns": "^2.6.0",
    "@types/jest": "^26.0.23",
    "@types/js-cookie": "^2.2.7",
    "@types/jsonwebtoken": "^8.5.4",
    "@types/mssql": "^7.1.3",
    "@types/node": "^15.12.2",
    "@types/nodemailer": "^6.4.4",
    "@types/nodemailer-express-handlebars": "^4.0.1",
    "@types/nookies": "^2.0.3",
    "@types/react": "^17.0.11",
    "@types/react-syntax-highlighter": "^13.5.2",
    "@types/react-tag-input": "^6.1.3",
    "@types/styled-components": "^5.1.10",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "babel-loader": "^8.2.2",
    "babel-plugin-styled-components": "^2.1.4",
    "css-loader": "^5.2.6",
    "eslint": "^8.57.0",
    "eslint-config-next": "12.2.5",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^3.4.0",
    "eslint-plugin-react": "^7.24.0",
    "eslint-plugin-react-hooks": "^4.2.0",
    "husky": "^6.0.0",
    "jest": "^27.0.4",
    "jest-styled-components": "^7.0.4",
    "lint-staged": "^11.0.0",
    "path": "^0.12.7",
    "plop": "^2.7.4",
    "prettier": "^2.3.1",
    "sass": "~1.32.12",
